# Copy to terraform.tfvars (git-ignored) and fill in your values.
# NEVER commit the real terraform.tfvars — it holds your API token.

proxmox_endpoint  = "https://10.0.0.44:8006/"
proxmox_api_token = "root@pam!terraform=<YOUR_TOKEN_UUID>"
proxmox_insecure  = true

node_name    = "uno"
lab_bridge   = "vmbr1"
datastore_id = "local-lvm"

# Override the starter lab here if you like. iso_file_id must point at an ISO
# already uploaded to Proxmox local storage.
lab_vms = {
  kali = {
    name        = "kali-attacker"
    vm_id       = 201
    cores       = 2
    memory      = 4096
    disk_size   = 30
    iso_file_id = "local:iso/kali-linux-installer-amd64.iso"
  }
  target = {
    name        = "metasploitable-target"
    vm_id       = 202
    cores       = 1
    memory      = 2048
    disk_size   = 16
    iso_file_id = "local:iso/metasploitable.iso"
  }
}
